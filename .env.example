# ── LLM API Keys ────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here

# ── Gemini Model ────────────────────────────────
GEMINI_MODEL=gemini-2.0-flash

# ── Whisper (STT) ───────────────────────────────
WHISPER_MODEL=tiny
RECORD_SECONDS=5

# ── Text-to-Speech ──────────────────────────────
TTS_VOICE=Hedda
TTS_RATE=165
TTS_VOLUME=1.0

# ── Broker / Scraper ────────────────────────────
NEWSAPI_KEY=your-newsapi-key-here
SERPAPI_API_KEY=your-serpapi-key-here
ALPHA_VANTAGE_API_KEY=your-alphavantage-key-here

# ── Scraper Interval (seconds) ──────────────────
SCRAPER_INTERVAL=600

# ── Scraper Cache TTL ───────────────────────────
# Default: 21600 (6h) — increased to 24h to save SerpAPI credits
SCRAPER_CACHE_TTL=86400

# ── Business / CRM ──────────────────────────────
# SerpAPI key for Business Skill (Google Business Profile scraping)
# Takes precedence over SERPAPI_API_KEY — leave empty to fall back
BUSINESS_SERPAPI_KEY=your-serpapi-key-here

# ── Skill Tenant Guard ──────────────────────────
# warn (default) — warns + prompts (continue / tenant <name> / no)
# auto            — warns + prompts for tenant name, creates + switches automatically
# off             — guard fully disabled (not recommended)
SKILL_TENANT_GUARD=warn

# ── Cloud Memory (Vercel) ───────────────────────
# Endpoint: https://your-project.vercel.app/api/memory
# Token:    choose freely — must match value set in Vercel env vars
CLOUD_MEMORY_URL=https://your-project.vercel.app/api/memory
CLOUD_MEMORY_TOKEN=your-token-here

# ── Local LLM (Stub) ────────────────────────────
# Leave empty = no local LLM provider (stub inactive)
# Ollama example:    LOCAL_LLM_URL=http://localhost:11434
# LM Studio example: LOCAL_LLM_URL=http://localhost:1234/v1
LOCAL_LLM_URL=
LOCAL_LLM_MODEL=

# ── UI Renderer ─────────────────────────────────
# "terminal" (default) or future renderer keys
ZUKI_UI=terminal

# ── GitHub Backup (code only — NOT data backup) ─
# Create a private repo on GitHub, then fill in below.
# Token: GitHub → Settings → Developer settings → Personal access tokens
# Required scope: repo (read + write)
# NOTE: .env is NEVER committed (.gitignore protects it)
GITHUB_REPO_URL=https://github.com/your-user/your-repo
GITHUB_TOKEN=your-github-pat-here
GITHUB_AUTOBACKUP=on
GITHUB_INTERVAL_HOURS=6
